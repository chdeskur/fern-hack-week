{
  "name": "@fern-platform/self-hosted",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "main": "index.js",
  "scripts": {
    "docker-scout:check": "docker scout cves fern-self-hosted:latest --format sarif --output sarif.json --only-severity critical,high --only-fixed",
    "docker:build": "docker buildx build ../../. --load -f Dockerfile.self_hosted -t fern-self-hosted:latest",
    "docker:run": "docker run -p 9000:9000 -p 9001:9001 -p 8080:8080 -p 3000:3000 -p 7700:7700 -it -v $(pwd)/fern:/fern -v $(pwd)/fern-docs:/fern-docs -v $(pwd)/scripts:/scripts fern-self-hosted:latest",
    "fdr:build": "pnpm --filter @fern-platform/fdr build:tsup:cjs",
    "test:self-hosted": "vitest src/__test__ --globals --config src/__test__/vitest.config.ts"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "execa": "^9.5.1",
    "vitest": "^3.0.5"
  }
}

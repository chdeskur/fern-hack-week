{
  "name": "@fern-api/docs-mdx",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/fern-api/fern-platform.git",
    "directory": "packages/commons/docs-mdx"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./bundler/serialize": {
      "types": "./dist/bundler/serialize.d.ts",
      "default": "./dist/bundler/serialize.js"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf ./lib && tsc --build --clean",
    "compile": "tsc --build",
    "depcheck": "depcheck",
    "dev": "tsc --watch",
    "format": "prettier --write --ignore-unknown \"**\"",
    "format:check": "prettier --check --ignore-unknown \"**\"",
    "lint:eslint": "eslint --max-warnings 0 .",
    "lint:eslint:fix": "pnpm lint:eslint --fix",
    "lint:style": "stylelint 'src/**/*.scss' --allow-empty-input --max-warnings 0",
    "lint:style:fix": "pnpm lint:style --fix",
    "test": "vitest --run --passWithNoTests --globals"
  },
  "dependencies": {
    "@fern-api/docs-server": "workspace:^",
    "@fern-api/docs-utils": "workspace:^",
    "@fern-api/fdr-sdk": "workspace:*",
    "@fern-api/ui-core-utils": "workspace:*",
    "@fern-docs/mdx": "workspace:^",
    "@vercel/kv": "^2.0.0",
    "es-toolkit": "^1.32.0",
    "estree-util-to-js": "^2.0.0",
    "estree-walker": "^3.0.3",
    "graceful-fs": "^4.2.11",
    "hast-util-properties-to-mdx-jsx-attributes": "^1.0.0",
    "hast-util-to-estree": "^3.1.1",
    "mdx-bundler": "^10.1.1",
    "next": "15.3.0-canary.1",
    "parse-numeric-range": "^1.3.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "rehype-katex": "^7.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gemoji": "^8.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-mdx-frontmatter": "^5.0.0",
    "remark-smartypants": "^3.0.2",
    "remark-squeeze-paragraphs": "^6.0.0",
    "server-only": "^0.0.1",
    "ts-essentials": "^10.0.4",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@fern-platform/configs": "workspace:*",
    "@types/graceful-fs": "^4.1.9",
    "@types/node": "^18.11.9",
    "@types/react": "19.0.10",
    "depcheck": "^1.4.7",
    "stylelint": "^16.1.0",
    "typescript": "^5",
    "vitest": "^3.0.5"
  }
}

{
  "extends": "@fern-platform/configs/tsconfig/nextjs.json",
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node", "next", "vitest/globals"],
    "strictNullChecks": true,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "../fern-docs/search-ui/**/*",
    "**/node_modules/**/*"
  ],
  "include": [
    "next.config.ts",
    ".next/types/**/*.ts",
    "src/**/*",
    "vitest.config.ts",
    "sentry.server.config.ts",
    "sentry.edge.config.ts"
  ],
  "references": [
    {
      "path": "../fai-sdk"
    },
    {
      "path": "../fdr-sdk"
    },
    {
      "path": "../commons/loadable"
    },
    {
      "path": "../commons/docs-loader"
    },
    {
      "path": "../commons/docs-server"
    },
    {
      "path": "../commons/docs-utils"
    },
    {
      "path": "../commons/fdr-utils"
    },
    {
      "path": "../fern-docs/components"
    },
    {
      "path": "../fern-docs/mdx"
    }
  ]
}

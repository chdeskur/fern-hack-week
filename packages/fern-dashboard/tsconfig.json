{
  "extends": "@fern-platform/configs/tsconfig/nextjs.json",
  "compilerOptions": {
    "rootDir": ".",
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node", "next", "vitest/globals"],
    "skipLibCheck": true
  },
  "exclude": ["node_modules"],
  "include": [
    "src/**/*",
    // ".next/types/**/*.ts",
    "next.config.ts",
    "vitest.config.ts"
  ],
  "references": [
    {
      "path": "../fdr-sdk"
    },
    {
      "path": "../commons/loadable"
    },
    {
      "path": "../commons/docs-loader"
    },
    {
      "path": "../commons/docs-mdx"
    },
    {
      "path": "../commons/docs-server"
    },
    {
      "path": "../commons/docs-utils"
    },
    {
      "path": "../commons/fdr-utils"
    },
    {
      "path": "../fern-docs/components"
    },
    {
      "path": "../fern-docs/mdx"
    }
  ]
}

{
  "name": "@fern-dashboard/ui",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/fern-api/fern-platform.git",
    "directory": "packages/fern-dashboard"
  },
  "sideEffects": false,
  "scripts": {
    "compile": "tsc --build",
    "dashboard:build": "next build",
    "dashboard:dev": "next dev",
    "dashboard:dev:inspect": "NODE_OPTIONS='--inspect' next dev",
    "dashboard:lint": "next lint",
    "dashboard:start": "next start",
    "db:migrate:dev": "dotenv -e .env.dev -- prisma migrate deploy --schema server/prisma/schema.prisma",
    "db:migrate:local": "dotenv -e .env.local -- prisma migrate deploy --schema server/prisma/schema.prisma",
    "db:migrate:prod": "dotenv -e .env.prod -- prisma migrate deploy --schema server/prisma/schema.prisma",
    "depcheck": "depcheck",
    "format": "prettier --write --ignore-unknown \"**\"",
    "format:check": "prettier --check --ignore-unknown \"**\"",
    "lint": "pnpm lint:eslint && pnpm lint:style",
    "lint:eslint": "eslint --max-warnings 0 . --ignore-pattern .next --ignore-pattern '**/*.{m,c,}js'",
    "lint:eslint:fix": "pnpm lint:eslint --fix",
    "lint:style": "stylelint 'src/**/*.scss' --allow-empty-input --max-warnings 0",
    "lint:style:fix": "pnpm lint:style --fix",
    "test": "vitest --run --passWithNoTests --globals",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@auth0/nextjs-auth0": "^4.6.1",
    "@aws-sdk/client-s3": "^3.744.0",
    "@aws-sdk/s3-request-presigner": "^3.744.0",
    "@bprogress/next": "^3.2.11",
    "@fern-api/docs-auth": "workspace:*",
    "@fern-api/docs-loader": "workspace:*",
    "@fern-api/docs-server": "workspace:*",
    "@fern-api/docs-utils": "workspace:*",
    "@fern-api/fai-sdk": "workspace:*",
    "@fern-api/fdr-sdk": "workspace:*",
    "@fern-api/ui-core-utils": "workspace:*",
    "@fern-api/venus-api-sdk": "^0.13.4-7-g5ff8ee8",
    "@fern-docs/components": "workspace:*",
    "@fern-docs/mdx": "workspace:*",
    "@fern-docs/search-ui": "workspace:*",
    "@fern-ui/loadable": "workspace:*",
    "@fern-ui/react-commons": "workspace:*",
    "@heroicons/react": "^2.2.0",
    "@mdx-js/react": "^3.1.0",
    "@microlink/react-json-view": "^1.26.1",

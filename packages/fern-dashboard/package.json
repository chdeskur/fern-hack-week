    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^18.19.76",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "dotenv-cli": "^6.0.0",
    "glslify-import": "^3.1.0",
    "glslify-loader": "^2.0.0",
    "prisma": "5.13.0",
    "raw-loader": "^4.0.2",
